# ============================================================
# Copiez ce fichier vers ".env" et renseignez vos propres valeurs.
# Ne jamais committer le fichier ".env" réel dans le contrôle de version.
# ============================================================

# ---- Environnement ----
FLASK_ENV=development

# ---- Sécurité ----
# Générez une clé robuste avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacez-moi-par-une-cle-secrete-aleatoire-et-longue

# ---- Base de données (production uniquement — PostgreSQL) ----
DATABASE_URL=postgresql://clinic_user:mot_de_passe@localhost:5432/clinic_production

# ---- Base de données (développement — SQLite, optionnel) ----
# DEV_DATABASE_URL=sqlite:///instance/clinic_dev.db

# ---- Cookies sécurisés (mettre à True derrière HTTPS en production) ----
SESSION_COOKIE_SECURE=False

# ---- Personnalisation du cabinet ----
CLINIC_NAME=Cabinet Médical Exemple
